FLASK_APP=app.py
# FLASK_DEBUG=true enables the interactive debugger and auto-reloader.
# FLASK_ENV (deprecated since Flask 2.3) is no longer recognised — use FLASK_DEBUG instead.
# Set to false (or omit entirely) in production.
FLASK_DEBUG=false

SECRET_KEY=change-me-to-a-long-random-string

# SQLite (local development, no setup required):
SQLALCHEMY_DATABASE_URI=sqlite:///dev.db
# MySQL example:
# SQLALCHEMY_DATABASE_URI=mysql+mysqlconnector://user:password@localhost:3306/grocery_management

# Email (Flask-Mail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=True

# Twilio SMS (optional — only needed for SMS notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1xxxxxxxxxx
